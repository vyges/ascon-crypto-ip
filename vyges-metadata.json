    }
  ],
  "interfaces": [
    {
      "type": "clock",
      "name": "clock",
      "signals": [
        {
          "name": "clk_i",
          "direction": "input",
          "type": "clock",
          "width": 1
        }
      ]
    },
    {
      "type": "reset",
      "name": "reset",
      "signals": [
        {
          "name": "rst_ni",
          "direction": "input",
          "type": "reset",
          "width": 1,
          "active_level": "low"
        }
      ]
    },
    {
      "type": "io",
      "name": "operation_control",
      "description": "Start pulse and per-operation mode. Inputs are latched on start_i.",
      "signals": [
        {
          "name": "start_i",
          "direction": "input",
          "width": 1,
          "description": "begin a new AEAD operation (single-cycle pulse)"
        },
        {
          "name": "decrypt_i",
          "direction": "input",
          "width": 1,
          "description": "0 = encrypt, 1 = decrypt"
        },
        {
          "name": "ad_empty_i",
          "direction": "input",
          "width": 1,
          "description": "1 = no associated data"
        },
        {
          "name": "ready_o",
          "direction": "output",
          "width": 1,
          "description": "core idle / can accept start"
        }
      ]
    },
    {
      "type": "io",
      "name": "key_nonce_tag",
      "description": "Key, nonce, and expected-tag inputs. Lane order {word1, word0}, little-endian bytes within a 64-bit lane.",
      "signals": [
        {
          "name": "key_i",
          "direction": "input",
          "width": 128,
          "description": "128-bit key {key1, key0}"
        },
        {
          "name": "npub_i",
          "direction": "input",
          "width": 128,
          "description": "128-bit public nonce {n1, n0}"
        },
        {
          "name": "exp_tag_i",
          "direction": "input",
          "width": 128,
          "description": "expected tag for decrypt verification"
        }
      ]
    },
    {
      "type": "io",
      "name": "associated_data",
      "description": "Associated-data rate-block stream (valid/ready). bytes = 16 for a full block, 0..15 for a partial last block.",
      "signals": [
        {
          "name": "ad_valid_i",
          "direction": "input",
          "width": 1
        },
        {
          "name": "ad_data_i",
          "direction": "input",
          "width": 128
        },
        {
          "name": "ad_bytes_i",
          "direction": "input",
          "width": 5
        },
        {
          "name": "ad_last_i",
          "direction": "input",
          "width": 1
        },
        {
          "name": "ad_ready_o",
          "direction": "output",
          "width": 1
        }
      ]
    },
    {
      "type": "io",
      "name": "message",
      "description": "Message rate-block stream: plaintext in / ciphertext out for encrypt, ciphertext in / plaintext out for decrypt.",
      "signals": [
        {
          "name": "msg_valid_i",
          "direction": "input",
          "width": 1
        },
        {
          "name": "msg_data_i",
          "direction": "input",
          "width": 128
        },
        {
          "name": "msg_bytes_i",
          "direction": "input",
          "width": 5
        },
        {
          "name": "msg_last_i",
          "direction": "input",
          "width": 1
        },
        {
          "name": "msg_ready_o",
          "direction": "output",
          "width": 1
        },
        {
          "name": "msg_data_o",
          "direction": "output",
          "width": 128,
          "description": "ciphertext (encrypt) or plaintext (decrypt)"
        },
        {
          "name": "msg_bytes_o",
          "direction": "output",
          "width": 5
        },
        {
          "name": "msg_valid_o",
          "direction": "output",
          "width": 1
        }
      ]
    },
    {
      "type": "io",
      "name": "result",
      "description": "Completion, computed tag, and decrypt tag-match.",
      "signals": [
        {
          "name": "done_o",
          "direction": "output",
          "width": 1,
          "description": "pulse: tag_o / tag_ok_o valid"
        },
        {
          "name": "tag_o",
          "direction": "output",
          "width": 128,
          "description": "128-bit authentication tag"
        },
        {
          "name": "tag_ok_o",
          "direction": "output",
          "width": 1,
          "description": "decrypt: 1 if computed tag matched exp_tag_i"
        }
      ]
    }
  ],
